# =========================================================================
# PDF AI Assistant - Unified Environment Variable Templates
# =========================================================================

# -------------------------------------------------------------------------
# Backend Configurations (Place in backend/.env)
# -------------------------------------------------------------------------

# Gemini API Key (Required for AI Insights)
GEMINI_API_KEY=your_gemini_api_key_here

# Azure Text-to-Speech Configuration (Optional, falls back to offline MP3 generation)
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_ENDPOINT=your_azure_tts_endpoint_here
AZURE_TTS_DEPLOYMENT=tts
AZURE_TTS_API_VERSION=2025-03-01-preview
AZURE_TTS_VOICE=alloy


# -------------------------------------------------------------------------
# Frontend Configurations (Place in frontend/.env)
# -------------------------------------------------------------------------

# Adobe PDF Embed API Client ID / API Key
VITE_ADOBE_API_KEY=your_adobe_api_key_here
